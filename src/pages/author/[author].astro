---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. STATIC PATHS GENERATION
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  
  // Filter out drafts
  const publicPosts = allPosts.filter(p => !p.data.draft);

  // Extract all unique authors
  const uniqueAuthors = [...new Set(publicPosts.map(post => post.data.author || 'Jonathan Mwaniki'))];

  // HELPER: Moved INSIDE getStaticPaths so Astro can access it during build
  function createSlug(text) {
    if (!text) return 'editorial-desk';
    return text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, '')  
      .replace(/\s+/g, '-')      
      .replace(/-+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  // Map each author to a dynamic route
  return uniqueAuthors.map(author => {
    const authorSlug = createSlug(author);
    
    // Filter posts belonging specifically to this author and sort newest first
    const authorPosts = publicPosts
      .filter(post => (post.data.author || 'Jonathan Mwaniki') === author)
      .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

    return {
      params: { author: authorSlug },
      props: { authorName: author, posts: authorPosts },
    };
  });
}

// 2. PAGE DATA
const { authorName, posts } = Astro.props;
const siteUrl = 'https://jonathanmwaniki.co.ke';
const currentUrl = new URL(Astro.url.pathname, siteUrl).href;

const title = `Articles by ${authorName} | The Mwaniki Report`;
const description = `Read all ${posts.length} articles written by ${authorName} on The Mwaniki Report.`;
---