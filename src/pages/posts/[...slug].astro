---
// src/pages/posts/[...slug].astro
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return new Response('Post not found', { status: 404 });
}

const post = await getEntry('posts', slug);

if (!post) {
  return new Response('Post not found', { status: 404 });
}

const { Content } = await post.render();

const formattedDate = post.data.date
  ? new Date(post.data.date).toLocaleDateString('en-KE', {
      year: 'numeric', month: 'long', day: 'numeric'
    })
  : '';
---

<Layout>
  <div class="jm-post-wrapper">
    <div class="jm-post-container">

      <!-- HEADER -->
      <header class="post-header">
        {post.data.category && (
          <a href={`/category/${post.data.category.toLowerCase()}`} class="post-cat-tag">
            {post.data.category}
          </a>
        )}
        <h1 class="post-title">{post.data.title}</h1>

        {post.data.description && (
          <p class="post-description">{post.data.description}</p>
        )}

        <div class="post-meta">
          {post.data.author && (
            <span class="post-author">By {post.data.author}</span>
          )}
          {formattedDate && (
            <time class="post-date">{formattedDate}</time>
          )}
        </div>
      </header>

      <!-- HERO IMAGE -->
      {post.data.image && (
        <div class="post-hero-img">
          <img
            src={post.data.image}
            alt={post.data.title}
            width="900"
            height="506"
            loading="eager"
          />
        </div>
      )}

      <!-- ARTICLE BODY -->
      <article class="post-body">
        <Content />
      </article>

      <!-- TAGS -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="post-tag">#{tag}</a>
          ))}
        </div>
      )}

    </div>
  </div>
</Layout>

<style is:global>
  .jm-post-wrapper {
    background: var(--jm-bg, #f8fafc);
    min-height: 100vh;
    padding: 2rem 0 5rem;
    color: var(--jm-text-main, #0f172a);
  }

  .jm-post-container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* HEADER */
  .post-header {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .post-cat-tag {
    display: inline-block;
    align-self: flex-start;
    background: var(--jm-accent, #ef4444);
    color: white;
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 12px;
    border-radius: 4px;
    text-decoration: none;
  }

  .post-title {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    font-weight: 900;
    line-height: 1.2;
    margin: 0;
    color: var(--jm-text-main, #0f172a);
  }

  .post-description {
    font-family: var(--jm-font-body, 'Merriweather', serif);
    font-size: 1.1rem;
    color: var(--jm-text-muted, #64748b);
    line-height: 1.65;
    margin: 0;
    border-left: 3px solid var(--jm-accent, #ef4444);
    padding-left: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-author {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--jm-text-main, #0f172a);
  }

  .post-date {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 0.82rem;
    color: var(--jm-text-muted, #64748b);
  }

  /* HERO IMAGE */
  .post-hero-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 2.5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .post-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ARTICLE BODY TYPOGRAPHY */
  .post-body {
    font-family: var(--jm-font-body, 'Merriweather', serif);
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--jm-text-main, #0f172a);
  }

  .post-body h2 {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 1.6rem;
    font-weight: 800;
    margin: 2.5rem 0 1rem;
    color: var(--jm-text-main, #0f172a);
    line-height: 1.25;
  }

  .post-body h3 {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 2rem 0 0.8rem;
    color: var(--jm-text-main, #0f172a);
  }

  .post-body h4 {
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 1.5rem 0 0.6rem;
    color: var(--jm-text-main, #0f172a);
  }

  .post-body p {
    margin: 0 0 1.5rem;
  }

  .post-body a {
    color: var(--jm-accent, #ef4444);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body ul,
  .post-body ol {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }

  .post-body li {
    margin-bottom: 0.5rem;
  }

  .post-body blockquote {
    border-left: 4px solid var(--jm-accent, #ef4444);
    padding: 0.75rem 1.25rem;
    margin: 2rem 0;
    background: rgba(239,68,68,0.04);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--jm-text-muted, #64748b);
  }

  .post-body img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
    display: block;
  }

  .post-body hr {
    border: none;
    border-top: 2px solid var(--jm-border, rgba(0,0,0,0.08));
    margin: 2.5rem 0;
  }

  .post-body code {
    background: #f1f5f9;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: monospace;
  }

  .post-body pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .post-body pre code {
    background: none;
    padding: 0;
    color: inherit;
  }

  /* TAGS */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--jm-border, rgba(0,0,0,0.08));
  }

  .post-tag {
    background: #f1f5f9;
    color: var(--jm-text-muted, #64748b);
    font-family: var(--jm-font-head, 'Inter', sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .post-tag:hover {
    background: var(--jm-accent, #ef4444);
    color: white;
  }
</style>

