---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

if (allPosts.length === 0) throw new Error("No posts found!");

const majorCategories = ['Politics', 'Business', 'Sports', 'Lifestyle', 'Technology'];
const isLive = (date) => (new Date() - new Date(date)) < 4 * 60 * 60 * 1000;

const storyCircles = allPosts.slice(0, 10).map(post => ({
  label: post.data.category || 'News',
  image: post.data.image,
  link: `/posts/${post.slug}`,
  live: isLive(post.data.date)
}));

const [heroMain, ...heroGrid] = allPosts.slice(0, 5);
const initialFeed = allPosts.slice(5, 13);

const hiddenFeed = allPosts.slice(13, 100).map(post => ({
  slug: post.slug,
  data: {
    title: post.data.title,
    category: post.data.category || 'News',
    date: post.data.date,
    description: post.data.description,
    image: post.data.image || '/default-image.jpg'
  }
}));
---

<Layout>
  <div class="jm-home-wrapper">

    <!-- PULSE BAR -->
    <section class="pulse-bar">
      <div class="jm-container">
        <div class="pulse-track">
          {storyCircles.map(item => (
            <a href={item.link} class="pulse-node">
              <div class={`ring-wrap ${item.live ? 'live' : ''}`}>
                <img src={item.image || '/default-image.jpg'} alt={item.label} width="64" height="64" loading="eager" />
                {item.live && <span class="live-badge">LIVE</span>}
              </div>
              <span class="pulse-label">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <main class="jm-container">

      <!-- HERO SECTION -->
      <section class="bento-grid no-ad-injection">

        <article class="bento-feature glass-panel">
          <a href={`/posts/${heroMain.slug}`} class="card-link">
            <div class="hero-img-wrap">
              <img src={heroMain.data.image || '/default-image.jpg'} alt={heroMain.data.title} width="800" height="450" loading="eager" />
            </div>
            <div class="hero-content">
              <span class="cat-tag">{heroMain.data.category}</span>
              <h1>{heroMain.data.title}</h1>
              <p class="excerpt">{heroMain.data.description}</p>
            </div>
          </a>
        </article>

        <div class="bento-stack">
          {heroGrid.map(post => (
            <a href={`/posts/${post.slug}`} class="mini-card glass-panel">
              <div class="mini-img">
                <img src={post.data.image || '/default-image.jpg'} alt={post.data.title} width="90" height="80" loading="lazy" />
              </div>
              <div class="mini-text">
                <span class="tiny-cat">{post.data.category}</span>
                <h3>{post.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- NEWS FEED -->
      <div class="content-split">

        <div class="feed-col">
          <div class="feed-header">
            <h2>Latest Updates</h2>
            <div class="line"></div>
          </div>

          <div id="feed-container" class="feed-grid">
            {initialFeed.map(post => (
              <article class="feed-card glass-panel">
                <a href={`/posts/${post.slug}`} class="card-link">
                  <div class="feed-img-wrap">
                    <img src={post.data.image || '/default-image.jpg'} alt={post.data.title} width="800" height="450" loading="lazy" />
                  </div>
                  <div class="feed-info">
                    <div class="meta">
                      <span class="meta-cat">{post.data.category}</span>
                      <time>{new Date(post.data.date).toLocaleDateString()}</time>
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>

          {hiddenFeed.length > 0 && (
            <div class="load-more-wrap">
              <button id="btn-load-more" class="btn-load-more">
                <span>Unroll More Stories</span>
              </button>
            </div>
          )}
        </div>

        <aside class="sidebar-col">
          <div class="sticky-box">
            <div class="widget glass-panel">
              <h4 class="widget-title">Trending Topics</h4>
              <div class="tag-cloud">
                {majorCategories.map(cat => (
                  <a href={`/category/${cat.toLowerCase()}`} class="tag-pill">{cat}</a>
                ))}
              </div>
            </div>
          </div>
        </aside>

      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ hiddenFeed }}>
  const loadBtn = document.getElementById('btn-load-more');
  const feedContainer = document.getElementById('feed-container');
  let loadedCount = 0;
  const BATCH_SIZE = 6;

  if (loadBtn) {
    loadBtn.addEventListener('click', () => {
      const nextBatch = hiddenFeed.slice(loadedCount, loadedCount + BATCH_SIZE);
      nextBatch.forEach(post => {
        const dateStr = new Date(post.data.date).toLocaleDateString();
        feedContainer.insertAdjacentHTML('beforeend', `
          <article class="feed-card glass-panel fade-in">
            <a href="/posts/${post.slug}" class="card-link">
              <div class="feed-img-wrap">
                <img src="${post.data.image}" alt="${post.data.title}" loading="lazy" width="800" height="450" />
              </div>
              <div class="feed-info">
                <div class="meta">
                  <span class="meta-cat">${post.data.category}</span>
                  <time>${dateStr}</time>
                </div>
                <h3>${post.data.title}</h3>
                <p>${post.data.description}</p>
              </div>
            </a>
          </article>
        `);
      });
      loadedCount += BATCH_SIZE;
      if (loadedCount >= hiddenFeed.length) loadBtn.style.display = 'none';
    });
  }
</script>

<style is:global>
  :root {
    --jm-bg: #f8fafc;
    --jm-card: rgba(255, 255, 255, 0.9);
    --jm-border: rgba(0, 0, 0, 0.08);
    --jm-text-main: #0f172a;
    --jm-text-muted: #64748b;
    --jm-accent: #ef4444;
    --jm-font-head: 'Inter', sans-serif;
    --jm-font-body: 'Merriweather', serif;
  }

  *, *::before, *::after { box-sizing: border-box; }

  body { margin: 0; padding: 0; background: var(--jm-bg); }

  a { text-decoration: none; color: inherit; }

  /* KEY FIX: only size images inside their own containers, never globally */
  .hero-img-wrap img,
  .mini-img img,
  .feed-img-wrap img,
  .ring-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .jm-home-wrapper {
    background-color: var(--jm-bg);
    color: var(--jm-text-main);
    font-family: var(--jm-font-body);
    width: 100%;
    padding-bottom: 4rem;
    min-height: 100vh;
  }

  .jm-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* GLASS PANEL */
  .glass-panel {
    background: var(--jm-card);
    border: 1px solid var(--jm-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .glass-panel:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
  }

  /* card-link: column layout so image is on top, text below */
  .card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  /* PULSE BAR */
  .pulse-bar {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--jm-border);
    margin-bottom: 2.5rem;
    background: white;
  }
  .pulse-track {
    display: flex;
    gap: 1.2rem;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }
  .pulse-track::-webkit-scrollbar { display: none; }
  .pulse-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    cursor: pointer;
  }
  .ring-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--jm-border);
    position: relative;
    flex-shrink: 0;
  }
  .ring-wrap.live { border-color: var(--jm-accent); }
  .live-badge {
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--jm-accent);
    color: white;
    font-size: 0.45rem;
    font-weight: 900;
    padding: 1px 4px;
    border-radius: 2px;
    font-family: var(--jm-font-head);
  }
  .pulse-label {
    font-family: var(--jm-font-head);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--jm-text-muted);
    text-align: center;
    width: 64px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* BENTO HERO GRID */
  .bento-grid {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  @media (min-width: 1024px) {
    .bento-grid { grid-template-columns: 2fr 1fr; }
  }

  /* Hero image container â€” fixed aspect ratio */
  .hero-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  /* Hero text content â€” always visible below image */
  .hero-content {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cat-tag {
    display: inline-block;
    align-self: flex-start;
    background: var(--jm-accent);
    color: white;
    font-family: var(--jm-font-head);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.65rem;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .hero-content h1 {
    font-family: var(--jm-font-head);
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    font-weight: 800;
    line-height: 1.25;
    margin: 0;
    color: var(--jm-text-main);
  }

  .excerpt {
    font-size: 0.95rem;
    color: var(--jm-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* BENTO STACK (small cards) */
  .bento-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mini-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem;
    text-decoration: none;
    color: inherit;
  }

  .mini-img {
    width: 88px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .mini-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tiny-cat {
    font-family: var(--jm-font-head);
    font-size: 0.6rem;
    color: var(--jm-accent);
    font-weight: 800;
    text-transform: uppercase;
  }

  .mini-text h3 {
    font-family: var(--jm-font-head);
    font-size: 0.88rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
    color: var(--jm-text-main);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* CONTENT SPLIT */
  .content-split {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 1024px) {
    .content-split { grid-template-columns: 1fr 300px; }
  }

  /* FEED */
  .feed-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .feed-header h2 {
    font-family: var(--jm-font-head);
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0;
    color: var(--jm-text-main);
    white-space: nowrap;
  }
  .feed-header .line {
    flex: 1;
    height: 2px;
    background: var(--jm-border);
  }

  .feed-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 600px) {
    .feed-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* feed card image container â€” fixed aspect ratio */
  .feed-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* feed card text â€” always visible below image */
  .feed-info {
    padding: 0.9rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .meta-cat {
    font-family: var(--jm-font-head);
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--jm-accent);
  }
  .meta time {
    font-family: var(--jm-font-head);
    font-size: 0.7rem;
    color: var(--jm-text-muted);
  }
  .feed-info h3 {
    font-family: var(--jm-font-head);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
    color: var(--jm-text-main);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .feed-info p {
    font-family: var(--jm-font-body);
    font-size: 0.82rem;
    color: var(--jm-text-muted);
    margin: 0;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* LOAD MORE */
  .load-more-wrap { text-align: center; margin-top: 2rem; }
  .btn-load-more {
    background: var(--jm-accent);
    color: white;
    border: none;
    padding: 0.8rem 2.5rem;
    border-radius: 8px;
    font-family: var(--jm-font-head);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-load-more:hover { opacity: 0.88; transform: translateY(-2px); }

  /* SIDEBAR */
  .sticky-box { position: sticky; top: 1.5rem; }
  .widget { padding: 1.25rem; }
  .widget-title {
    font-family: var(--jm-font-head);
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1rem 0;
    color: var(--jm-text-main);
  }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag-pill {
    background: var(--jm-bg);
    border: 1px solid var(--jm-border);
    color: var(--jm-text-muted);
    font-family: var(--jm-font-head);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    transition: background 0.2s, color 0.2s;
  }
  .tag-pill:hover { background: var(--jm-accent); color: white; border-color: var(--jm-accent); }

  /* FADE IN */
  .fade-in { animation: fadeIn 0.35s ease forwards; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

