---
// src/pages/posts/[...slug].astro

import { getEntry } from 'astro:content';
// import Layout from '../../layouts/Layout.astro'; // <-- Import your actual layout here

// 1. Tell Astro NOT to build this page statically.
// This enables Server-Side Rendering (SSR) to handle millions of posts without crashing Vercel.
export const prerender = false;

// 2. Get the requested slug directly from the URL
const { slug } = Astro.params;

if (!slug) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// 3. Fetch ONLY the requested post from the "posts" collection dynamically
const post = await getEntry('posts', slug);

// 4. If the post doesn't exist, return a 404
if (!post) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// 5. Render the markdown/MDX content
const { Content } = await post.render();
---

<!-- Wrap this in your site's existing Layout component -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{post.data.title}</title>
    <!-- Add your other meta tags/SEO here -->
  </head>
  <body>
    <main>
      <article>
        <h1>{post.data.title}</h1>

        <!-- Render the actual post content -->
        <Content />
      </article>
    </main>
  </body>
</html>
