{
  "crons": [
    {
      "path": "/api/cron/submit-sitemap",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "render.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|avif|ico|svg|woff2|woff)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/.*",
      "headers": {
        "X-Content-Type-Options": "nosniff"
      }
    }
  ]
}
